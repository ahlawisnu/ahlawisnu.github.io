---
layout: null
permalink: /manifest.json
---
{
  "name": "{{ site.title }}",
  "short_name": "{{ site.title | replace: ' ', '-' }}",
  "description": "{{ site.description }}",
  "start_url": "{{ '/' | relative_url }}",
  "display": "standalone",
  "background_color": "{{ site.background_color | default: '#FEF7FF' }}",
  "theme_color": "{{ site.theme_color | default: '#6750A4' }}",
  "orientation": "any",
  "scope": "/",
  "icons": [
    {
      "src": "{{ '/assets/images/icons/icon-192x192.png' | relative_url }}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "{{ '/assets/images/icons/icon-512x512.png' | relative_url }}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
